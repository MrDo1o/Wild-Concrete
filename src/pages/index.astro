---
import "../styles/global.css";

const siteUrl = "https://wildconcrete.studio";
const pageTitle = "Wild Concrete Studio";
const pageDescription = "Color-forward editorial florals with clear pricing and secure checkout options.";
const socialImage = `${siteUrl}/og-wild-concrete.png`;

const products = [
  {
    name: "Canopy Study No. 01",
    subtitle: "Sculptural Orchid + Anthurium",
    description: "High-contrast stem architecture for entry consoles and gallery-style living rooms.",
    sku: "WC-ST-01",
    price: "$145",
    priceCents: 14500,
    image: "https://placehold.co/900x1125/7a1c1c/f5f2eb?text=Editorial+Study+01"
  },
  {
    name: "Heatline Arrangement",
    subtitle: "Heliconia + Ginger Composition",
    description: "A vertical, color-forward arrangement built for clean interiors and bold focal walls.",
    sku: "WC-ST-02",
    price: "$128",
    priceCents: 12800,
    image: "https://placehold.co/900x1125/c65a2e/f5f2eb?text=Editorial+Study+02"
  },
  {
    name: "Moss Form Edit",
    subtitle: "Tropical Greens + Texture",
    description: "Soft foliage layered with strict linework for a calm but elevated presentation.",
    sku: "WC-ST-03",
    price: "$118",
    priceCents: 11800,
    image: "https://placehold.co/900x1125/4a5d4d/f5f2eb?text=Editorial+Study+03"
  },
  {
    name: "Lilac Drift Piece",
    subtitle: "Pastel Accent + Dense Bloom",
    description: "An expressive pastel set designed to break up monochrome spaces with intentional softness.",
    sku: "WC-ST-04",
    price: "$132",
    priceCents: 13200,
    image: "https://placehold.co/900x1125/c8b6d6/0b0b0b?text=Editorial+Study+04"
  },
  {
    name: "Concrete Bloom Stack",
    subtitle: "Mixed Tropical Signature",
    description: "Editorial mixed stems with asymmetry and depth for hospitality or studio reception styling.",
    sku: "WC-ST-05",
    price: "$164",
    priceCents: 16400,
    image: "https://placehold.co/900x1125/0b0b0b/f5f2eb?text=Editorial+Study+05"
  },
  {
    name: "Director's Cut Bundle",
    subtitle: "3-Piece Seasonal Rotation",
    description: "Quarterly color rotation with premium stems and on-brand composition guidance.",
    sku: "WC-ST-06",
    price: "$380",
    priceCents: 38000,
    image: "https://placehold.co/900x1125/cfc7bd/0b0b0b?text=Editorial+Bundle"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#f5f2eb" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={pageTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Wild Concrete Studio logo and wordmark." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
  </head>
  <body class="wc-body">
    <main class="site-shell" id="index">
      <header class="topbar">
        <p class="brand-kicker">Wild Concrete Studio</p>
        <nav>
          <a href="#intro">Intro</a>
          <a href="#collection">Collection</a>
          <a href="#checkout">Checkout</a>
        </nav>
      </header>

      <section class="hero" aria-label="Hero">
        <div class="hero-wordmark" role="img" aria-label="Wild Concrete Studio">
          <p class="line">WILD</p>
          <p class="line">CONCRETE</p>
          <p class="studio">STUDIO</p>
        </div>
        <p class="hero-copy">Softness, shaped by structure. Editorial florals for high-intent spaces.</p>
        <div class="hero-swatches" aria-hidden="true">
          <span class="swatch swatch-red"></span>
          <span class="swatch swatch-orange"></span>
          <span class="swatch swatch-green"></span>
          <span class="swatch swatch-lilac"></span>
        </div>
      </section>

      <section class="section" id="intro">
        <h2>Studio Direction</h2>
        <p class="section-copy">This is a color-driven editorial storefront: premium arrangements, clear pricing, and a direct path to checkout.</p>
        <div class="manifesto-grid">
          <article>
            <h3>Color + Control</h3>
            <p>Deep neutrals for structure, expression tones for the florals.</p>
          </article>
          <article>
            <h3>Design-First Commerce</h3>
            <p>A studio aesthetic with conversion-ready sections and API checkout hooks.</p>
          </article>
          <article>
            <h3>Operationally Ready</h3>
            <p>Frontend payload contract already wired for Square, Cash App Pay, Apple Pay, and Google Pay.</p>
          </article>
        </div>
      </section>

      <section class="section" id="collection">
        <h2>Collection + Pricing</h2>
        <p class="section-copy">Current studies and bundles. Swap placeholders for catalog images any time.</p>
        <div class="product-grid">
          {products.map((item) => (
            <article class="product-card">
              <img src={item.image} alt={`${item.name} placeholder`} loading="lazy" />
              <div class="product-body">
                <p class="subtitle">{item.subtitle}</p>
                <h3>{item.name}</h3>
                <p class="description">{item.description}</p>
                <div class="meta">
                  <span>{item.sku}</span>
                  <strong>{item.price}</strong>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="checkout">
        <h2>Checkout</h2>
        <p class="section-copy">Customer checkout with provider routing and backend API contract already in place.</p>

        <div class="checkout-grid">
          <form class="panel" id="checkout-form" novalidate>
            <div class="fields">
              <label class="field full">
                <span>Customer Name</span>
                <input id="customerName" name="customerName" autocomplete="name" required />
              </label>
              <label class="field">
                <span>Email</span>
                <input id="email" name="email" type="email" autocomplete="email" required />
              </label>
              <label class="field">
                <span>Phone</span>
                <input id="phone" name="phone" autocomplete="tel" />
              </label>
              <label class="field">
                <span>Product</span>
                <select id="sku" name="sku">
                  {products.map((item) => (
                    <option value={item.sku} data-name={item.name} data-price-cents={item.priceCents}>{item.name} ({item.price})</option>
                  ))}
                </select>
              </label>
              <label class="field">
                <span>Quantity</span>
                <input id="quantity" name="quantity" type="number" value="1" min="1" max="50" required />
              </label>
              <label class="field full">
                <span>Delivery Address</span>
                <input id="addressLine1" name="addressLine1" autocomplete="address-line1" />
              </label>
              <label class="field">
                <span>City</span>
                <input id="city" name="city" autocomplete="address-level2" />
              </label>
              <label class="field">
                <span>State</span>
                <input id="state" name="state" autocomplete="address-level1" />
              </label>
              <label class="field">
                <span>Zip</span>
                <input id="postalCode" name="postalCode" autocomplete="postal-code" />
              </label>
              <label class="field full">
                <span>Order Notes</span>
                <textarea id="notes" name="notes" placeholder="Card message, delivery timing, special requests"></textarea>
              </label>
            </div>

            <h3 class="pay-heading">Payment Method</h3>
            <div class="pay-options">
              <label><input type="radio" name="paymentMethod" value="square_card" checked /> Card (Square)</label>
              <label><input type="radio" name="paymentMethod" value="cash_app_pay" /> Cash App Pay</label>
              <label><input type="radio" name="paymentMethod" value="apple_pay" /> Apple Pay</label>
              <label><input type="radio" name="paymentMethod" value="google_pay" /> Google Pay</label>
            </div>

            <div class="actions">
              <button type="submit">Create Secure Checkout</button>
              <button type="button" class="ghost" id="simulateBtn">Simulate API Response</button>
            </div>
            <p class="status" id="checkoutStatus" aria-live="polite"></p>
          </form>

          <aside class="panel summary">
            <h3>Order Summary</h3>
            <div class="row"><span id="summaryItem">Canopy Study No. 01</span><span id="summaryPrice">$145.00</span></div>
            <div class="row"><span>Quantity</span><span id="summaryQty">1</span></div>
            <div class="row"><span>Subtotal</span><span id="summarySubtotal">$145.00</span></div>
            <div class="row"><span>Service + Handling</span><span>$14.50</span></div>
            <div class="row total"><span>Total</span><span id="summaryTotal">$159.50</span></div>
            <p class="api-note">
              API contract is active. Frontend posts JSON payload to provider route and expects
              <code>checkoutUrl</code> in response.
            </p>
          </aside>
        </div>
      </section>
    </main>

    <script is:inline>
      const CHECKOUT_API_BASE =
        window.WC_CHECKOUT_API_BASE || "https://wild-concrete-checkout-api.mrdo1o.workers.dev";
      const HANDLING_FEE_RATE = 0.1;
      const providerRoutes = {
        square_card: "/checkout/square/card-session",
        cash_app_pay: "/checkout/square/cash-app-session",
        apple_pay: "/checkout/square/apple-pay-session",
        google_pay: "/checkout/square/google-pay-session"
      };

      const form = document.getElementById("checkout-form");
      const skuSelect = document.getElementById("sku");
      const qtyInput = document.getElementById("quantity");
      const statusEl = document.getElementById("checkoutStatus");
      const simulateBtn = document.getElementById("simulateBtn");

      const summaryItem = document.getElementById("summaryItem");
      const summaryPrice = document.getElementById("summaryPrice");
      const summaryQty = document.getElementById("summaryQty");
      const summarySubtotal = document.getElementById("summarySubtotal");
      const summaryTotal = document.getElementById("summaryTotal");

      const toUsd = (cents) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD" }).format(cents / 100);

      function getSelectedProduct() {
        const option = skuSelect.selectedOptions[0];
        return {
          sku: option.value,
          name: option.dataset.name,
          priceCents: Number(option.dataset.priceCents || 0)
        };
      }

      function getQuantity() {
        const value = Number(qtyInput.value || 1);
        return Math.max(1, Math.min(50, Math.floor(value)));
      }

      function renderSummary() {
        const product = getSelectedProduct();
        const qty = getQuantity();
        const subtotal = product.priceCents * qty;
        const fee = Math.round(subtotal * HANDLING_FEE_RATE);

        summaryItem.textContent = product.name;
        summaryPrice.textContent = toUsd(product.priceCents);
        summaryQty.textContent = String(qty);
        summarySubtotal.textContent = toUsd(subtotal);
        summaryTotal.textContent = toUsd(subtotal + fee);
      }

      function setStatus(text, type = "") {
        statusEl.textContent = text;
        statusEl.className = "status" + (type ? " " + type : "");
      }

      function buildPayload() {
        const product = getSelectedProduct();
        const qty = getQuantity();
        const subtotalCents = product.priceCents * qty;
        const feeCents = Math.round(subtotalCents * HANDLING_FEE_RATE);
        const totalCents = subtotalCents + feeCents;
        const paymentMethod = form.querySelector("input[name='paymentMethod']:checked")?.value || "square_card";

        return {
          source: "wildconcrete.studio",
          paymentMethod,
          customer: {
            name: form.customerName.value.trim(),
            email: form.email.value.trim(),
            phone: form.phone.value.trim()
          },
          shipping: {
            addressLine1: form.addressLine1.value.trim(),
            city: form.city.value.trim(),
            state: form.state.value.trim(),
            postalCode: form.postalCode.value.trim()
          },
          items: [
            {
              sku: product.sku,
              name: product.name,
              quantity: qty,
              unitAmountCents: product.priceCents
            }
          ],
          notes: form.notes.value.trim(),
          amounts: {
            subtotalCents,
            feeCents,
            totalCents,
            currency: "USD"
          }
        };
      }

      async function createCheckoutSession(payload) {
        const route = providerRoutes[payload.paymentMethod];
        if (!route) {
          throw new Error("Unsupported payment method.");
        }

        const response = await fetch(CHECKOUT_API_BASE + route, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const body = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(body.message || "Checkout API call failed.");
        }
        return body;
      }

      skuSelect.addEventListener("change", renderSummary);
      qtyInput.addEventListener("input", renderSummary);

      simulateBtn.addEventListener("click", () => {
        const payload = buildPayload();
        const fakeUrl = "https://checkout.example.com/session/" + encodeURIComponent(payload.items[0].sku);
        setStatus("Simulated session created. Redirect target: " + fakeUrl, "success");
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;

        try {
          setStatus("Creating secure checkout session...");
          const payload = buildPayload();
          const result = await createCheckoutSession(payload);
          if (result.checkoutUrl) {
            setStatus("Redirecting to hosted checkout...", "success");
            window.location.href = result.checkoutUrl;
            return;
          }
          setStatus("Session created but no checkoutUrl returned. Check API response.", "error");
        } catch (error) {
          const message = error instanceof Error ? error.message : "Checkout request failed.";
          setStatus(message + " Set window.WC_CHECKOUT_API_BASE to your live API host.", "error");
        }
      });

      renderSummary();
    </script>
  </body>
</html>
